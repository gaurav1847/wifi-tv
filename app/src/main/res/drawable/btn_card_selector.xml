<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused state (D-pad highlight) -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#1A3A7A" />
            <stroke android:width="3dp" android:color="#4488FF" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#2244AA" />
            <stroke android:width="2dp" android:color="#6699FF" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- Normal state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#111830" />
            <stroke android:width="1dp" android:color="#223366" />
            <corners android:radius="16dp" />
        </shape>
    </item>

</selector>
