<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base TV theme -->
    <style name="Theme.WifiResetTV" parent="@style/Theme.Leanback">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:colorPrimary">@color/blue_primary</item>
        <item name="android:colorAccent">@color/blue_accent</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
    </style>

    <!-- Transparent dialog theme -->
    <style name="Theme.WifiResetTV.Dialog" parent="android:Theme.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>
