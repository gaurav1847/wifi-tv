<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A1A"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="48dp">

    <!-- App Title -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📶"
            android:textSize="64sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="WiFi Reset Tool"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Root-powered network reset for Android TV"
            android:textColor="#8899BB"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="300dp"
        android:layout_height="1dp"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="40dp"
        android:background="#223366" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:weightSum="3">

        <!-- Button 1: Forget All WiFi Networks -->
        <LinearLayout
            android:id="@+id/btnForgetWifi"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:layout_margin="12dp"
            android:layout_weight="1"
            android:background="@drawable/btn_card_selector"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:nextFocusLeft="@id/btnForgetWifi"
            android:nextFocusRight="@id/btnNetworkReset"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🗑️"
                android:textSize="42sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="Forget All\nWiFi Networks"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="Removes all saved\nWiFi passwords"
                android:textColor="#7788AA"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Button 2: Reset Network Settings -->
        <LinearLayout
            android:id="@+id/btnNetworkReset"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:layout_margin="12dp"
            android:layout_weight="1"
            android:background="@drawable/btn_card_selector"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:nextFocusLeft="@id/btnForgetWifi"
            android:nextFocusRight="@id/btnFactoryWifi"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔄"
                android:textSize="42sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="Reset Network\nSettings"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="Resets WiFi, Bluetooth\n&amp; mobile data settings"
                android:textColor="#7788AA"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Button 3: Full WiFi Factory Reset -->
        <LinearLayout
            android:id="@+id/btnFactoryWifi"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:layout_margin="12dp"
            android:layout_weight="1"
            android:background="@drawable/btn_card_selector_red"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:nextFocusLeft="@id/btnNetworkReset"
            android:nextFocusRight="@id/btnFactoryWifi"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠️"
                android:textSize="42sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="Full WiFi\nFactory Reset"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="Wipes all WiFi data\nas if factory reset"
                android:textColor="#FFAAAA"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Status Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:background="@drawable/status_card_bg"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STATUS LOG"
            android:textColor="#4466AA"
            android:textSize="11sp"
            android:letterSpacing="0.15" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Ready. Select an action using D-pad or remote control."
            android:textColor="#AABBCC"
            android:textSize="14sp" />

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="12dp"
            android:indeterminate="true"
            android:progressTint="#3366FF"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Root Check Badge -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvRootStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/badge_bg"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:text="⏳ Checking root access..."
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

    </LinearLayout>

</LinearLayout>
